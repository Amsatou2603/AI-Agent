# ==============================================================================
# Fichier d'exemple de configuration — copier en .env et compléter les valeurs.
# Ne JAMAIS committer le fichier .env (il est dans .gitignore).
# ==============================================================================

# ------------------------------------------------------------------------------
# Django — obligatoire
# Générer une clé avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ------------------------------------------------------------------------------
SECRET_KEY=remplacer-par-une-vraie-cle-secrete

# Mettre à False en production
DEBUG=True

# Hosts autorisés en production (séparés par des virgules), ex: monsite.com,www.monsite.com
ALLOWED_HOSTS=

# ------------------------------------------------------------------------------
# BONUS — LLM externe (optionnel)
# Laisser vides pour utiliser uniquement l'analyseur déterministe.
# ------------------------------------------------------------------------------
LLM_API_KEY=
LLM_API_URL=
